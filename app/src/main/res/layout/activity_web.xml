<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    >

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="false"
        >

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center_vertical"
            >

            <EditText
                android:id="@+id/urlBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_url_bar"
                android:hint="URL or search..."
                android:inputType="textUri"
                android:imeOptions="actionGo"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:textSize="13sp"
                />

            <ImageButton
                android:id="@+id/btnGo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_forward"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:contentDescription="Go"
                />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/pageProgress"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:visibility="gone"
            />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        >

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swiperefreshlayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            >

            <android.webkit.WebView
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- DevTools Panel -->
        <LinearLayout
            android:id="@+id/devToolsPanel"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="?attr/colorSurface"
            android:elevation="8dp"
            >

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutlineVariant"
                />

            <!-- Tab Bar -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:scrollbars="none"
                android:fillViewport="true"
                >

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    >

                    <Button
                        android:id="@+id/tabConsole"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Console"
                        android:textSize="12sp"
                        />

                    <Button
                        android:id="@+id/tabElements"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Elements"
                        android:textSize="12sp"
                        />

                    <Button
                        android:id="@+id/tabNetwork"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Network"
                        android:textSize="12sp"
                        />

                    <Button
                        android:id="@+id/tabStorage"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Storage"
                        android:textSize="12sp"
                        />

                </LinearLayout>

            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutlineVariant"
                />

            <!-- Console Tab -->
            <LinearLayout
                android:id="@+id/consoleContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible"
                >

                <ScrollView
                    android:id="@+id/consoleScroll"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="?attr/colorSurfaceVariant"
                    >

                    <TextView
                        android:id="@+id/consoleOutput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:textSize="12sp"
                        android:textIsSelectable="true"
                        />

                </ScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp"
                    >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:fontFamily="monospace"
                        android:textSize="18sp"
                        android:paddingEnd="6dp"
                        />

                    <EditText
                        android:id="@+id/consoleInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="JS expression..."
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:imeOptions="actionSend"
                        android:inputType="text"
                        android:background="@null"
                        />

                    <ImageButton
                        android:id="@+id/consoleClear"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_delete"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="6dp"
                        android:contentDescription="Clear"
                        />

                </LinearLayout>

            </LinearLayout>

            <!-- Elements Tab -->
            <LinearLayout
                android:id="@+id/elementsContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    >

                    <Button
                        android:id="@+id/btnPickElement"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Pick Element"
                        android:textSize="12sp"
                        />

                    <Button
                        android:id="@+id/btnRefreshDom"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Refresh DOM"
                        android:textSize="12sp"
                        />

                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSurfaceVariant"
                    >

                    <TextView
                        android:id="@+id/domTree"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:textSize="11sp"
                        android:textIsSelectable="true"
                        />

                </ScrollView>

            </LinearLayout>

            <!-- Network Tab -->
            <LinearLayout
                android:id="@+id/networkContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingEnd="8dp"
                    >

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Network Requests"
                        android:textSize="12sp"
                        android:paddingStart="12dp"
                        />

                    <Button
                        android:id="@+id/btnClearNetwork"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Clear"
                        android:textSize="12sp"
                        />

                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSurfaceVariant"
                    >

                    <TextView
                        android:id="@+id/networkLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:textSize="11sp"
                        android:textIsSelectable="true"
                        />

                </ScrollView>

            </LinearLayout>

            <!-- Storage Tab -->
            <LinearLayout
                android:id="@+id/storageContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                >

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:scrollbars="none"
                    >

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:paddingStart="8dp"
                        android:gravity="center_vertical"
                        >

                        <Button
                            android:id="@+id/btnLocalStorage"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="localStorage"
                            android:textSize="12sp"
                            />

                        <Button
                            android:id="@+id/btnSessionStorage"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="sessionStorage"
                            android:textSize="12sp"
                            />

                        <Button
                            android:id="@+id/btnCookies"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Cookies"
                            android:textSize="12sp"
                            />

                    </LinearLayout>

                </HorizontalScrollView>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSurfaceVariant"
                    >

                    <TextView
                        android:id="@+id/storageOutput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:padding="8dp"
                        android:textSize="11sp"
                        android:textIsSelectable="true"
                        />

                </ScrollView>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- DevTools FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabDevTools"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        app:srcCompat="@drawable/ic_bug_report"
        app:fabSize="mini"
        android:contentDescription="DevTools"
        />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
